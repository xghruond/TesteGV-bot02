# Credenciais Twilio — copie este arquivo para .env e preencha
# Encontre no console: https://console.twilio.com

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número Twilio comprado (preenche automaticamente após comprar via API)
TWILIO_PHONE_NUMBER=

# Porta do servidor (padrão 3001)
PORT=3001
