# ============================================================
# Green BOT — Backend Twilio
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env real — ele está no .gitignore
# ============================================================

# Credenciais Twilio — console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número Twilio ativo (preenchido automaticamente ao comprar)
TWILIO_PHONE_NUMBER=

# Chave secreta para autenticar o frontend com o backend
# Gere uma chave forte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=cole-aqui-uma-chave-aleatoria-forte

# Porta do servidor (padrão 3001)
PORT=3001
